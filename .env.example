# Optional: E-Mail-Benachrichtigung bei neuen Anfragen
# Wenn gesetzt, sendet die API zusätzlich eine Mail an diese Adresse.
CONTACT_NOTIFY_EMAIL=

# Absenderadresse für die Benachrichtigung (muss bei Resend verifiziert sein).
CONTACT_FROM_EMAIL=no-reply@fensterbau-meister.de

# Resend API Key — wenn gesetzt, wird Resend als Mailprovider genutzt.
# https://resend.com — kostenfreies Kontingent für kleinere Volumen
RESEND_API_KEY=
